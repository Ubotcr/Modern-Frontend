    "@astrojs/mdx": "5.0.4",
    "@astrojs/sitemap": "3.7.2",
    "astro": "^6.3.1",
    "remark-collapse": "^0.1.2",
    "remark-toc": "^9.0.0",
    "sharp": "^0.34.5",
    "vite": "^7"
  },
  "devDependencies": {
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.2.4",
    "@types/node": "25.6.0",
    "concurrently": "^9.2.1",
    "prettier": "^3.8.3",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "tailwindcss": "^4.2.4",
    "typescript": "^6.0.3"
  },
  "pnpm": {
