---
import config from "@/config/config.json";
import "@/styles/main.css";
import { Font } from "astro:assets";
import Header from "./partials/Header.astro";
import Footer from "./partials/Footer.astro";

export interface Props {
  title?: string;
  meta_title?: string;
  description?: string;
  image?: string;
  noindex?: boolean;
  canonical?: string;
}

const { title, meta_title, description, image, noindex, canonical } =
  Astro.props;
const pageTitle = meta_title || title || config.site.title;
const pageDescription = description || config.metadata.meta_description;
const pageImage = image || config.metadata.meta_image;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />

    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />
    <meta name="author" content={config.metadata.meta_author} />
    {noindex && <meta name="robots" content="noindex,nofollow" />}
    {canonical && <link rel="canonical" href={canonical} />}

    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:type" content="website" />
    <meta
      property="og:url"
      content={`${config.site.base_url}${Astro.url.pathname}`}
    />
    <meta property="og:image" content={`${config.site.base_url}${pageImage}`} />

    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDescription} />
    <meta
      name="twitter:image"
      content={`${config.site.base_url}${pageImage}`}
    />
    <meta name="twitter:card" content="summary_large_image" />

    <link rel="icon" type="image/svg+xml" href="/icon.svg" />
    <link rel="icon" href="/favicon.ico" sizes="32x32" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="theme-color" content="#0f1117" />
    <meta name="generator" content={Astro.generator} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Material+Symbols+Rounded:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200&display=swap"
      rel="stylesheet"
    />

    <Font cssVariable="--font-primary" preload />
  </head>
  <body class="bg-body text-text-light font-primary antialiased">
    <a href="#main-content" class="skip-link">Saltar al contenido</a>
    <Header />
    <main id="main-content">
      <slot />
    </main>
    <Footer />
  </body>
</html>
