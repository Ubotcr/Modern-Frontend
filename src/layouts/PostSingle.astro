---
import BlogCard from "@/components/BlogCard.astro";
import { getCollection, render } from "astro:content";
import { formatDate, isoDate, readingTime } from "@/lib/utils/blog";

interface Props {
  post: any;
}

const { post } = Astro.props;
const { title, description, image, category, author, date } = post.data;
const { Content, headings } = await render(post);

const readTime = post.body ? readingTime(post.body) : "";

const all = await getCollection(
  "blog",
  ({ id, data }) => !id.startsWith("-") && !id.startsWith("_") && !data.draft,
);
const related = all
  .filter((p: any) => p.id !== post.id && p.data.category === category)
  .sort(
    (a: any, b: any) =>
      new Date(b.data.date || 0).getTime() -
      new Date(a.data.date || 0).getTime(),
  )
  .slice(0, 3)
  .map((p: any) => ({ frontmatter: p.data, slug: p.id, content: p.body }));

const toc = (headings || []).filter((h: any) => h.depth >= 2 && h.depth <= 3);
---

<section class="px-4 py-12 md:py-16">
  <div class="container mx-auto max-w-3xl">
    <div class="flex flex-col items-center gap-4 text-center">
      {
        category && (
          <span class="rounded-full bg-primary/10 px-3 py-1 text-xs font-semibold text-primary">
            {category}
          </span>
        )
      }
      <h1
        class="text-3xl font-extrabold text-text-light md:text-4xl lg:text-5xl"
      >
        {title}
      </h1>
      {
        description && (
          <p class="mx-auto mt-1 max-w-2xl text-text">{description}</p>
        )
      }
      <div
        class="mt-3 flex flex-wrap items-center justify-center gap-x-3 gap-y-1 text-sm text-gray"
      >
        {
          author?.name && (
            <span class="font-medium text-text">{author.name}</span>
          )
        }
        {author?.name && date && <span aria-hidden="true">&middot;</span>}
        {date && <time datetime={isoDate(date)}>{formatDate(date)}</time>}
        {readTime && <span aria-hidden="true">&middot;</span>}
        {readTime && <span>{readTime}</span>}
      </div>
    </div>

    {
      image && (
        <img
          src={image}
          alt=""
          width="1200"
          height="675"
          class="mt-10 aspect-[16/9] w-full rounded-2xl border border-border object-cover"
        />
      )
    }
  </div>
</section>

<section class="px-4 pb-12 md:pb-16">
  <div class="container mx-auto max-w-6xl">
    <div class="grid gap-10 lg:grid-cols-[1fr_220px]">
      <div>
        <div class="content">
          <Content />
        </div>
      </div>

      {
        toc.length > 0 && (
          <aside>
            <div class="lg:sticky lg:top-24">
              <nav aria-label="Tabla de contenidos">
                <h2 class="mb-3 text-sm font-semibold uppercase tracking-wide text-text-light">
                  Contenido
                </h2>
                <ul class="space-y-1">
                  {toc.map((h: any) => (
                    <li class={h.depth === 3 ? "pl-4" : ""}>
                      <a
                        href={`#${h.slug}`}
                        class="block py-1 text-sm text-gray transition-colors hover:text-text-light"
                      >
                        {h.text}
                      </a>
                    </li>
                  ))}
                </ul>
              </nav>
            </div>
          </aside>
        )
      }
    </div>
  </div>
</section>

{
  related.length > 0 && (
    <section class="border-t border-border px-4 py-12 md:py-16">
      <div class="container mx-auto max-w-6xl">
        <h2 class="mb-8 text-center text-2xl font-bold text-text-light md:text-3xl">
          Entradas relacionadas
        </h2>
        <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
          {related.map((p) => (
            <BlogCard data={p} />
          ))}
        </div>
      </div>
    </section>
  )
}
