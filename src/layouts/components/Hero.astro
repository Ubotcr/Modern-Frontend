---
import { markdownify } from "@/lib/utils/textConverter";
import Icon from "@/components/Icon.astro";
import Logo from "@/components/Logo.astro";
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";

import logoUCR from "../../../public/images/logos/UCR.png";
import logoUNA from "../../../public/images/logos/UNA.svg";
import logoTEC from "../../../public/images/logos/TEC.svg";

interface Props {
  data: any;
}

const { data } = Astro.props;
const logos = [
  { src: logoUCR, alt: "Universidad de Costa Rica" },
  { src: logoUNA, alt: "Universidad Nacional de Costa Rica" },
  { src: logoTEC, alt: "Tecnológico de Costa Rica" },
];
// Los logos se muestran a 96-112px; con padding (p-4) el espacio real es 64-80px.
// 160px cubre retina (2x80px). SVG se mantienen vectoriales.
const logoWidth = (meta: ImageMetadata) =>
  meta.format === "svg" ? undefined : 160;
---

<section class="relative overflow-hidden px-4 pb-20 pt-14 text-center md:pt-16">
  <div class="container mx-auto max-w-5xl">
    <div class="mb-8 mt-6">
      <div class="flex flex-wrap items-center justify-center gap-4 md:gap-6">
        {
          logos.map((logo) => (
            <div
              class="flex h-24 w-24 items-center justify-center rounded-2xl border border-border bg-light p-4 shadow-sm transition-transform hover:-translate-y-1 md:h-28 md:w-28"
              title={logo.alt}
            >
              <Image
                src={logo.src}
                alt={logo.alt}
                width={logoWidth(logo.src)}
                class="h-full w-full object-contain"
                loading="eager"
              />
            </div>
          ))
        }
      </div>
    </div>

    <h1
      class="mx-auto max-w-3xl font-extrabold leading-tight text-text-light"
      style="font-size: clamp(2.25rem, 6vw, 3.75rem); text-wrap: balance;"
      set:html={markdownify(data.title).__html}
    />

    <p
      class="mx-auto mt-6 max-w-xl text-lg text-text"
      style="text-wrap: pretty;"
    >
      {data.content}
    </p>

    <div class="mt-8 flex flex-wrap items-center justify-center gap-4">
      {
        data.button_primary?.enable && (
          <a
            href={data.button_primary.link}
            target="_blank"
            rel="noopener noreferrer"
            class="btn btn-primary btn-lg"
          >
            <Icon name="sports_esports" class="text-lg" filled />
            {data.button_primary.label}
          </a>
        )
      }
      {
        data.button_secondary?.enable && (
          <a href={data.button_secondary.link} class="btn btn-outline btn-lg">
            {data.button_secondary.label}
          </a>
        )
      }
    </div>
  </div>
</section>
