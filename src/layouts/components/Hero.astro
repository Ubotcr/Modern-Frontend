---
import { markdownify } from "@/lib/utils/textConverter";
import Icon from "@/components/Icon.astro";
import { Image } from "astro:assets";

import logoUCR from "../../../public/images/logos/UCR.png";
import logoUNA from "../../../public/images/logos/UNA.svg";
import logoTEC from "../../../public/images/logos/TEC.svg";

interface Props {
  data: any;
}

const { data } = Astro.props;
const logos = [
  { src: logoUCR, alt: "Universidad de Costa Rica" },
  { src: logoUNA, alt: "Universidad Nacional de Costa Rica" },
  { src: logoTEC, alt: "Tecnológico de Costa Rica" },
];
---

<section class="relative overflow-hidden px-4 pb-20 pt-14 text-center md:pt-16">
  <div
    class="absolute inset-x-0 top-0 -z-10 h-[60%] bg-linear-to-b from-primary/5 to-transparent"
  >
  </div>

  <div class="container mx-auto max-w-5xl">
    <div class="mb-8 mt-6">
      <div class="flex flex-wrap items-center justify-center gap-4 md:gap-6">
        {
          logos.map((logo) => (
            <div
              class="flex h-24 w-24 items-center justify-center rounded-2xl border border-border bg-light p-4 shadow-sm transition-transform hover:-translate-y-1 md:h-28 md:w-28"
              title={logo.alt}
            >
              <Image
                src={logo.src}
                alt={logo.alt}
                class="h-full w-full object-contain"
                loading="eager"
                fetchpriority="high"
              />
            </div>
          ))
        }
      </div>
    </div>

    <h1
      class="mx-auto max-w-3xl text-4xl font-extrabold leading-tight text-text-light md:text-5xl lg:text-6xl"
      set:html={markdownify(data.title).__html}
    />

    <p class="mx-auto mt-6 max-w-xl text-lg text-gray">
      {data.content}
    </p>

    <div class="mt-8 flex flex-wrap items-center justify-center gap-4">
      {
        data.button_primary?.enable && (
          <a
            href={data.button_primary.link}
            target="_blank"
            rel="noopener noreferrer"
            class="btn btn-primary btn-lg"
          >
            <Icon name="school" class="text-lg" filled />
            {data.button_primary.label}
          </a>
        )
      }
      {
        data.button_secondary?.enable && (
          <a href={data.button_secondary.link} class="btn btn-outline btn-lg">
            {data.button_secondary.label}
          </a>
        )
      }
    </div>

    {
      data.stats && (
        <div
          class="mt-12 flex flex-wrap justify-center gap-4"
          role="list"
          aria-label="Estadísticas de Ubot"
        >
          {data.stats.map((stat: any) => (
            <div
              class="flex min-w-28 flex-col items-center gap-1 rounded-xl border border-border bg-card px-6 py-4"
              role="listitem"
            >
              <span class="text-2xl font-extrabold text-primary">
                {stat.value}
              </span>
              <span class="text-xs uppercase tracking-wide text-gray">
                {stat.label}
              </span>
            </div>
          ))}
        </div>
      )
    }
  </div>
</section>
