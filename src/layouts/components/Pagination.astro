---
import Icon from "@/components/Icon.astro";

interface Props {
  section: string;
  currentPage: number;
  totalPages: number;
}

const { section, currentPage, totalPages } = Astro.props;
const base = section ? `/${section}` : "";
const pageHref = (n: number) => (n <= 1 ? base : `${base}/page/${n}`);
const pages = Array.from({ length: totalPages }, (_, i) => i + 1);

const linkClass =
  "flex h-10 w-10 items-center justify-center rounded-lg border border-border text-sm text-text-light transition-colors hover:border-primary hover:text-primary";
const disabledClass = "pointer-events-none opacity-40";
---

{
  totalPages > 1 && (
    <nav
      class="mt-10 flex flex-wrap items-center justify-center gap-2"
      aria-label="Paginación"
    >
      <a
        href={pageHref(currentPage - 1)}
        class:list={[linkClass, currentPage === 1 && disabledClass]}
        aria-label="Página anterior"
      >
        <Icon name="chevron_left" class="text-xl" />
      </a>

      {pages.map((n) =>
        n === currentPage ? (
          <span
            aria-current="page"
            class="flex h-10 w-10 items-center justify-center rounded-lg bg-primary text-sm font-semibold text-white"
          >
            {n}
          </span>
        ) : (
          <a href={pageHref(n)} class={linkClass} aria-label={`Página ${n}`}>
            {n}
          </a>
        ),
      )}

      <a
        href={pageHref(currentPage + 1)}
        class:list={[linkClass, currentPage === totalPages && disabledClass]}
        aria-label="Página siguiente"
      >
        <Icon name="chevron_right" class="text-xl" />
      </a>
    </nav>
  )
}
