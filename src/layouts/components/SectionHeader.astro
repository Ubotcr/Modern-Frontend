---
interface Props {
  title: string;
  subtitle?: string;
}

const { title, subtitle } = Astro.props;
---

<div class="mb-12 text-center md:mb-16">
  <h2
    class="mt-4 font-bold text-text-light"
    style="font-size: clamp(1.875rem, 4vw, 2.25rem); text-wrap: balance;"
  >{title}</h2>
  {subtitle && (
    <p class="mx-auto mt-4 max-w-xl text-text" style="text-wrap: pretty;">
      {subtitle}
    </p>
  )}
</div>
