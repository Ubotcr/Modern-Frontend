---
import Icon from "@/components/Icon.astro";

interface Props {
  data: any;
}

const { data } = Astro.props;
const { title, description, button, enable } = data.frontmatter;
---

{
  enable && (
    <section class="px-4 py-12 md:py-20">
      <div class="container mx-auto max-w-3xl">
        <div class="relative overflow-hidden rounded-2xl border border-primary/20 bg-gradient-dark px-6 py-14 text-center shadow-lg md:px-12 md:py-20">
          <div class="absolute -right-16 -top-16 h-48 w-48 rounded-full bg-primary/10 blur-3xl" />
          <div class="absolute -bottom-16 -left-16 h-48 w-48 rounded-full bg-primary/10 blur-3xl" />

          <h2
            class="relative font-bold text-text-light"
            style="font-size: clamp(1.875rem, 4vw, 2.25rem); text-wrap: balance;"
          >
            {title}
          </h2>
          <p class="relative mx-auto mt-4 max-w-xl text-text">{description}</p>
          {button?.enable && (
            <a
              href={button.link}
              target="_blank"
              rel="noopener noreferrer"
              class="btn btn-primary btn-lg relative mt-8 inline-flex"
            >
              <Icon name="rocket_launch" class="text-lg" filled />
              {button.label}
            </a>
          )}
        </div>
      </div>
    </section>
  )
}
