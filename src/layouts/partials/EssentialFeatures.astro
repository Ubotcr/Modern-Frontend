---
import SectionHeader from "@/components/SectionHeader.astro";
import Icon from "@/components/Icon.astro";

interface Props {
  data: any;
}

const { data } = Astro.props;
const { title, features } = data.frontmatter;
---

<section class="px-4 py-16 md:py-24">
  <div class="container mx-auto max-w-6xl">
    <SectionHeader title={title} />

    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {
        features.map((feature: any) => (
          <article class="group relative rounded-xl border border-border bg-card p-6 shadow-sm transition-all hover:-translate-y-0.5 hover:border-primary/30 hover:shadow-md">
            <span class="flex h-12 w-12 items-center justify-center rounded-xl bg-primary/10 text-2xl text-primary">
              <Icon name={feature.icon} class="text-[1.5rem]" />
            </span>
            <h3 class="mt-4 text-lg font-semibold text-text-light">
              {feature.title}
            </h3>
            <p class="mt-2 text-sm leading-relaxed text-text">
              {feature.content}
            </p>
            {feature.premium && (
              <span class="absolute right-4 top-4 rounded-full bg-premium/10 px-2 py-1 text-xs font-semibold text-premium">
                Premium
              </span>
            )}
          </article>
        ))
      }
    </div>
  </div>
</section>
