---
import SectionHeader from "@/components/SectionHeader.astro";
import Icon from "@/components/Icon.astro";

interface Props {
  data: any;
}

const { data } = Astro.props;
const { title, features, included } = data.frontmatter;
---

<section class="px-4 py-16 md:py-24">
  <div class="container mx-auto max-w-6xl">
    <SectionHeader title={title} />

    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {
        features.map((feature: any) => (
          <article class="group relative rounded-xl border border-border bg-card p-6 shadow-sm transition-all hover:-translate-y-0.5 hover:border-primary/30 hover:shadow-md">
            <span class="flex h-12 w-12 items-center justify-center rounded-xl bg-primary/10 text-primary">
              <Icon name={feature.icon} class="text-2xl" />
            </span>
            <h3 class="mt-4 text-lg font-semibold text-text-light">
              {feature.title}
            </h3>
            <p class="mt-2 text-sm leading-relaxed text-text">
              {feature.content}
            </p>
          </article>
        ))
      }
    </div>

    {
      included && included.length > 0 && (
        <div class="mt-10 md:mt-12">
          <p class="mb-5 text-sm font-medium text-gray">
            También incluido
          </p>
          <div class="grid gap-4 sm:grid-cols-3">
            {included.map((item: any) => (
              <div class="flex items-start gap-3 rounded-lg border border-border bg-card/50 px-4 py-3.5">
                <span class="flex h-9 w-9 shrink-0 items-center justify-center rounded-lg bg-primary/10 text-primary">
                  <Icon name={item.icon} class="text-lg" />
                </span>
                <div class="min-w-0">
                  <div class="flex items-center gap-2">
                    <h4 class="text-sm font-semibold text-text-light">{item.title}</h4>
                    {item.premium && (
                      <span class="rounded-full bg-premium/10 px-1.5 py-0.5 text-[0.625rem] font-semibold text-premium">
                        Premium
                      </span>
                    )}
                  </div>
                  <p class="mt-0.5 text-xs leading-relaxed text-text">
                    {item.content}
                  </p>
                </div>
              </div>
            ))}
          </div>
        </div>
      )
    }
  </div>
</section>
