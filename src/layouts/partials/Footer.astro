---
import config from "@/config/config.json";
import menu from "@/config/menu.json";
import social from "@/config/social.json";

const { footer_company, footer_product, footer_legal } = menu;
const { params, site } = config;

import { Image } from "astro:assets";
// Import image from public directly for Astro processing
import schoolLogo from "../../../public/images/school.png";
---

<footer class="border-t border-border bg-card" style="padding-bottom: env(safe-area-inset-bottom);">
  <div class="mx-auto w-full max-w-7xl px-4 py-6 sm:px-6 lg:px-8 lg:py-8">
    <div class="grid gap-12 md:grid-cols-2 lg:grid-cols-5 lg:gap-8">
      <div class="lg:col-span-2">
        <a
          href="/"
          class="flex items-center gap-2 text-lg font-bold text-text-light no-underline"
        >
          <Image src={schoolLogo} alt="" width={24} height={24} loading="lazy" />
          <span>{site.logo_text}</span>
        </a>
        <p class="mt-4 text-sm leading-relaxed text-gray">
          {params.footer_text}
        </p>
        <a
          href={`mailto:${params.mail}`}
          class="mt-4 inline-block text-sm text-link hover:underline"
        >
          {params.mail}
        </a>
        <div class="mt-6 flex flex-wrap gap-3">
          {
            social.main.map((item) => (
              <a
                href={item.link}
                target="_blank"
                rel="noopener noreferrer"
                aria-label={item.name}
                class="flex h-9 w-9 items-center justify-center rounded-md border border-border text-gray transition-colors hover:border-primary hover:text-primary"
              >
                {item.name === "facebook" && (
                  <svg
                    width="16"
                    height="16"
                    viewBox="0 0 24 24"
                    fill="currentColor"
                    aria-hidden="true"
                  >
                    <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z" />
                  </svg>
                )}
                {item.name === "instagram" && (
                  <svg
                    width="16"
                    height="16"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    aria-hidden="true"
                  >
                    <rect x="2" y="2" width="20" height="20" rx="5" ry="5" />
                    <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z" />
                    <line x1="17.5" y1="6.5" x2="17.51" y2="6.5" />
                  </svg>
                )}
                {item.name === "tiktok" && (
                  <svg
                    width="16"
                    height="16"
                    viewBox="0 0 24 24"
                    fill="currentColor"
                    aria-hidden="true"
                  >
                    <path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-2.88 2.5 2.89 2.89 0 0 1-2.89-2.89 2.89 2.89 0 0 1 2.89-2.89c.28 0 .54.04.79.1V9.01a6.3 6.3 0 0 0-.79-.05 6.34 6.34 0 0 0-6.34 6.34 6.34 6.34 0 0 0 6.34 6.34 6.34 6.34 0 0 0 6.33-6.34V8.69a8.27 8.27 0 0 0 4.84 1.56V6.79a4.85 4.85 0 0 1-1.07-.1z" />
                  </svg>
                )}
              </a>
            ))
          }
        </div>
      </div>

      <div>
        <h3
          class="mb-4 text-sm font-semibold uppercase tracking-wide text-text-light"
        >
          Ubot
        </h3>
        <ul class="space-y-3">
          {
            footer_company.map((item) => (
              <li>
                <a
                  href={item.url}
                  class="text-sm text-gray hover:text-text-light"
                >
                  {item.name}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <div>
        <h3
          class="mb-4 text-sm font-semibold uppercase tracking-wide text-text-light"
        >
          Producto
        </h3>
        <ul class="space-y-3">
          {
            footer_product.map((item) => (
              <li>
                <a
                  href={item.url}
                  target={item.url.startsWith("http") ? "_blank" : undefined}
                  rel={
                    item.url.startsWith("http")
                      ? "noopener noreferrer"
                      : undefined
                  }
                  class="text-sm text-gray hover:text-text-light"
                >
                  {item.name}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <div>
        <h3
          class="mb-4 text-sm font-semibold uppercase tracking-wide text-text-light"
        >
          Legal
        </h3>
        <ul class="space-y-3">
          {
            footer_legal.map((item) => (
              <li>
                <a
                  href={item.url}
                  class="text-sm text-gray hover:text-text-light"
                >
                  {item.name}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

    </div>

    <div class="mt-6 border-t border-border pt-8 text-center text-sm text-gray">
      {params.copyright}
    </div>
  </div>
</footer>
