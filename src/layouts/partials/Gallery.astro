---
import SectionHeader from "@/components/SectionHeader.astro";
import { Image, getImage } from "astro:assets";
import { resolvePublicImage } from "@/lib/utils/image";

interface Props {
  data: any;
}

const { data } = Astro.props;
const { title, subtitle, images, enable } = data.frontmatter;

// Pre-genera una versión optimizada de alta resolución para el lightbox.
// Se sirve una sola imagen (1600px, webp/avif) en lugar del PNG original.
const lightboxSources = await Promise.all(
  (images ?? []).map(async (item: { src: string; caption?: string }) => {
    const meta = resolvePublicImage(item.src);
    if (!meta) return { fullSrc: item.src };
    const full = await getImage({ src: meta, width: 1600 });
    return { fullSrc: full.src };
  }),
);
---

{
  enable && (
    <section
      id="gallery"
      class="border-y border-border bg-card px-4 py-12 md:py-20"
    >
      <div class="container mx-auto max-w-6xl">
        <SectionHeader title={title} subtitle={subtitle} />

        <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
          {images.map(
            (item: { src: string; caption?: string }, index: number) => {
              const src = item.src;
              const caption = item.caption ?? `Captura de Ubot ${index + 1}`;
              const imageObj = resolvePublicImage(src);
              const fullSrc = lightboxSources[index]?.fullSrc ?? src;
              return (
                <button
                  type="button"
                  class="group block cursor-pointer overflow-hidden rounded-xl border border-border bg-card text-left shadow-sm transition-all hover:-translate-y-1 hover:shadow-md"
                  data-gallery-trigger
                  data-index={index}
                  data-caption={caption}
                  data-full-src={fullSrc}
                  aria-label={`Ampliar: ${caption}`}
                >
                  {imageObj ? (
                    <Image
                      src={imageObj}
                      alt={caption}
                      widths={[400, 800, 1200]}
                      sizes="(max-width: 640px) 100vw, (max-width: 1023px) 50vw, 33vw"
                      class="gallery-image block h-auto w-full object-cover transition-transform duration-300 group-hover:scale-105"
                      loading="lazy"
                    />
                  ) : (
                    <img
                      src={src}
                      alt={caption}
                      loading="lazy"
                      class="gallery-image block h-auto w-full object-cover transition-transform duration-300 group-hover:scale-105"
                    />
                  )}
                  <figcaption class="border-t border-border px-4 py-3 text-xs leading-snug text-gray">
                    {caption}
                  </figcaption>
                </button>
              );
            },
          )}
        </div>
      </div>
    </section>
  )
}

<div
  id="gallery-lightbox"
  class="fixed inset-0 z-[100] hidden items-center justify-center bg-black/80 p-4 opacity-0 transition-opacity duration-300 backdrop-blur-sm"
  role="dialog"
  aria-modal="true"
  aria-label="Visor de capturas de pantalla"
>
  <button
    id="lightbox-close"
    class="absolute right-4 top-4 z-10 flex h-12 w-12 items-center justify-center rounded-full bg-black/50 text-white transition-colors hover:bg-black/70 focus-visible:outline-none"
    aria-label="Cerrar visor"
  >
    <svg
      width="24"
      height="24"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
      aria-hidden="true"
    >
      <line x1="18" y1="6" x2="6" y2="18"></line>
      <line x1="6" y1="6" x2="18" y2="18"></line>
    </svg>
  </button>
  <button
    id="lightbox-prev"
    class="absolute left-2 top-1/2 z-10 flex h-12 w-12 -translate-y-1/2 items-center justify-center rounded-full bg-black/50 text-white transition-colors hover:bg-black/70 focus-visible:outline-none md:left-4"
    aria-label="Imagen anterior"
  >
    <svg
      width="24"
      height="24"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
      aria-hidden="true"
    >
      <polyline points="15 18 9 12 15 6"></polyline>
    </svg>
  </button>
  <button
    id="lightbox-next"
    class="absolute right-2 top-1/2 z-10 flex h-12 w-12 -translate-y-1/2 items-center justify-center rounded-full bg-black/50 text-white transition-colors hover:bg-black/70 focus-visible:outline-none md:right-4"
    aria-label="Imagen siguiente"
  >
    <svg
      width="24"
      height="24"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
      aria-hidden="true"
    >
      <polyline points="9 18 15 12 9 6"></polyline>
    </svg>
  </button>
  <figure
    class="mx-auto flex max-h-full max-w-full flex-col items-center gap-3"
  >
    <img
      id="lightbox-img"
      src=""
      alt=""
      class="max-h-[85vh] max-w-[90vw] rounded-lg object-contain shadow-2xl transition-transform duration-300 scale-95"
    />
    <figcaption id="lightbox-caption" class="text-sm text-white/80">
    </figcaption>
  </figure>
</div>

<script>
  function initLightbox() {
    const triggers = document.querySelectorAll<HTMLButtonElement>(
      "[data-gallery-trigger]",
    );
    const lightbox = document.getElementById("gallery-lightbox");
    const lightboxImg = document.getElementById(
      "lightbox-img",
    ) as HTMLImageElement;
    const captionEl = document.getElementById("lightbox-caption");
    const closeBtn = document.getElementById(
      "lightbox-close",
    ) as HTMLButtonElement | null;
    const prevBtn = document.getElementById(
      "lightbox-prev",
    ) as HTMLButtonElement | null;
    const nextBtn = document.getElementById(
      "lightbox-next",
    ) as HTMLButtonElement | null;

    if (!lightbox || !lightboxImg || !closeBtn || triggers.length === 0) return;

    // Build the image list from the rendered trigger buttons.
    const items = Array.from(triggers).map((btn) => {
      const img = btn.querySelector("img");
      const caption = btn.dataset.caption ?? "";
      const fullSrc = btn.dataset.fullSrc || img?.src || "";
      return { src: fullSrc, alt: img?.alt ?? "Captura de Ubot", caption };
    });

    let currentIndex = 0;
    let lastFocused: HTMLElement | null = null;
    const focusable = [closeBtn, prevBtn, nextBtn].filter(
      (b): b is HTMLButtonElement => Boolean(b),
    );

    const prefersReducedMotion = window.matchMedia(
      "(prefers-reduced-motion: reduce)",
    ).matches;

    const showImage = (index: number) => {
      currentIndex = (index + items.length) % items.length;
      const item = items[currentIndex];
      if (!item) return;
      lightboxImg.src = item.src;
      lightboxImg.alt = item.alt;
      if (captionEl) {
        captionEl.textContent = `${item.caption}  ·  ${currentIndex + 1} / ${items.length}`;
      }
    };

    const openLightbox = (index: number, trigger: HTMLElement) => {
      lastFocused = trigger;
      showImage(index);
      lightbox.classList.remove("hidden");
      requestAnimationFrame(() => {
        lightbox.classList.remove("opacity-0");
        if (!prefersReducedMotion) {
          lightboxImg.classList.remove("scale-95");
          lightboxImg.classList.add("scale-100");
        } else {
          lightboxImg.classList.remove("scale-95");
        }
      });
      document.body.style.overflow = "hidden";
      closeBtn.focus();
    };

    const closeLightbox = () => {
      lightbox.classList.add("opacity-0");
      lightboxImg.classList.remove("scale-100");
      lightboxImg.classList.add("scale-95");
      const restore = () => {
        lightbox.classList.add("hidden");
        document.body.style.overflow = "";
        lastFocused?.focus();
        lastFocused = null;
      };
      if (prefersReducedMotion) {
        restore();
      } else {
        setTimeout(restore, 300);
      }
    };

    triggers.forEach((btn) => {
      btn.addEventListener("click", () => {
        const idx = Number(btn.dataset.index ?? "0");
        openLightbox(idx, btn);
      });
    });

    closeBtn.addEventListener("click", closeLightbox);
    prevBtn?.addEventListener("click", () => showImage(currentIndex - 1));
    nextBtn?.addEventListener("click", () => showImage(currentIndex + 1));

    lightbox.addEventListener("click", (e) => {
      if (e.target === lightbox) closeLightbox();
    });

    lightbox.addEventListener("keydown", (e) => {
      if (lightbox.classList.contains("hidden")) return;
      switch (e.key) {
        case "Escape":
          e.preventDefault();
          closeLightbox();
          break;
        case "ArrowLeft":
          e.preventDefault();
          showImage(currentIndex - 1);
          break;
        case "ArrowRight":
          e.preventDefault();
          showImage(currentIndex + 1);
          break;
        case "Tab": {
          e.preventDefault();
          const active = document.activeElement as HTMLButtonElement | null;
          const i = active ? focusable.indexOf(active) : -1;
          if (e.shiftKey) {
            focusable[(i - 1 + focusable.length) % focusable.length].focus();
          } else {
            focusable[(i + 1) % focusable.length].focus();
          }
          break;
        }
      }
    });
  }

  document.addEventListener("astro:page-load", initLightbox);
  initLightbox();
</script>
