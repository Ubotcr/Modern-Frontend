---
import config from "@/config/config.json";
import menu from "@/config/menu.json";
import Icon from "@/components/Icon.astro";

const { navigation_button, site } = config;
const currentPath = Astro.url.pathname;

import { Image } from "astro:assets";
import schoolLogo from "../../../public/images/school.png";

interface NavItem {
  name: string;
  url: string;
  children?: NavItem[];
}
const { main } = menu as { main: NavItem[] };
---

<header
  class="sticky top-0 z-50 border-b border-border bg-body/95 backdrop-blur transition-all duration-300"
  style="padding-top: env(safe-area-inset-top);"
>
  <div class="mx-auto w-full max-w-7xl px-4 sm:px-6 lg:px-8">
    <nav
      class="flex h-16 items-center justify-between"
      aria-label="Navegación principal"
    >
      <a
        href="/"
        class="flex items-center gap-2 text-lg font-bold text-text-light no-underline"
      >
        <Image
          src={schoolLogo}
          alt=""
          width={28}
          height={28}
          class="block"
          loading="eager"
          fetchpriority="high"
        />
        <span>{site.logo_text}</span>
      </a>

      <ul class="hidden items-center gap-1 md:flex">
        {
          main.map((item) => {
            const isActive = item.children
              ? item.children.some(
                  (c) =>
                    currentPath === c.url ||
                    currentPath.startsWith(c.url + "/"),
                )
              : currentPath === item.url ||
                currentPath.startsWith(item.url + "/");
            return (
              <li>
                {item.children?.length ? (
                  <div class="group relative" data-dropdown>
                    <button
                      type="button"
                      class:list={[
                        "flex items-center gap-1 rounded-md px-3 py-2 text-sm font-medium transition-colors",
                        isActive
                          ? "text-link"
                          : "text-gray hover:text-text-light",
                      ]}
                      aria-haspopup="true"
                      aria-expanded="false"
                      data-dropdown-trigger
                    >
                      {item.name}
                      <Icon
                        name="expand_more"
                        class="text-base transition-transform group-data-[open=true]:rotate-180"
                      />
                    </button>
                    <ul
                      class="invisible absolute left-0 top-full z-50 mt-1 min-w-[12rem] rounded-lg border border-border bg-card p-1 opacity-0 shadow-lg transition-all duration-150 group-data-[open=true]:visible group-data-[open=true]:opacity-100"
                      data-dropdown-menu
                    >
                      {item.children.map((child) => (
                        <li>
                          <a
                            href={child.url}
                            class="block whitespace-nowrap rounded-md px-3 py-2 text-sm text-gray transition-colors hover:bg-body hover:text-text-light"
                          >
                            {child.name}
                          </a>
                        </li>
                      ))}
                    </ul>
                  </div>
                ) : (
                  <a
                    href={item.url}
                    class:list={[
                      "rounded-md px-3 py-2 text-sm font-medium transition-colors",
                      isActive
                        ? "text-link"
                        : "text-gray hover:text-text-light",
                    ]}
                  >
                    {item.name}
                  </a>
                )}
              </li>
            );
          })
        }
      </ul>

      <div class="hidden items-center gap-3 md:flex">
        {
          navigation_button.enable && (
            <a
              href={navigation_button.link}
              target="_blank"
              rel="noopener noreferrer"
              class="btn btn-primary text-sm"
            >
              {navigation_button.label}
            </a>
          )
        }
      </div>

      <button
        id="menu-toggle"
        class="relative flex h-10 w-10 items-center justify-center rounded-lg border border-border text-text-light transition-colors hover:bg-card md:hidden"
        aria-label="Abrir menú"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <Icon
          name="menu"
          class="absolute text-2xl transition-all duration-300 ease-in-out"
          id="menu-open-icon"
        />
        <Icon
          name="close"
          class="absolute text-2xl opacity-0 scale-50 -rotate-90 transition-all duration-300 ease-in-out"
          id="menu-close-icon"
        />
      </button>
    </nav>
  </div>

  <div
    id="mobile-menu"
    class="grid grid-rows-[0fr] bg-body opacity-0 transition-all duration-300 ease-in-out md:hidden"
  >
    <div class="overflow-hidden">
      <div
        class="container mx-auto flex flex-col gap-1 px-4 py-4 border-t border-border"
      >
        {
          main.map((item) =>
            item.children?.length ? (
              <div class="flex flex-col">
                <span class="px-3 pb-1 pt-3 text-xs font-semibold uppercase tracking-wide text-gray">
                  {item.name}
                </span>
                {item.children.map((child) => (
                  <a
                    href={child.url}
                    class="rounded-md px-6 py-2.5 text-text-light transition-colors hover:bg-card"
                    data-close-menu
                  >
                    {child.name}
                  </a>
                ))}
              </div>
            ) : (
              <a
                href={item.url}
                class="rounded-md px-3 py-3 text-text-light transition-colors hover:bg-card"
                data-close-menu
              >
                {item.name}
              </a>
            ),
          )
        }
        {
          navigation_button.enable && (
            <a
              href={navigation_button.link}
              target="_blank"
              rel="noopener noreferrer"
              class="btn btn-primary mt-2 text-center text-sm"
              data-close-menu
            >
              {navigation_button.label}
            </a>
          )
        }
      </div>
    </div>
  </div>
</header>

<script>
  function initHeader() {
    const toggle = document.getElementById("menu-toggle");
    const mobileMenu = document.getElementById("mobile-menu");
    if (!toggle || !mobileMenu) return;

    const openIcon = document.getElementById("menu-open-icon");
    const closeIcon = document.getElementById("menu-close-icon");
    let isOpen = false;

    const closeMenu = () => {
      isOpen = false;

      mobileMenu.classList.remove("grid-rows-[1fr]", "opacity-100");
      mobileMenu.classList.add("grid-rows-[0fr]", "opacity-0");

      toggle.setAttribute("aria-expanded", "false");
      toggle.setAttribute("aria-label", "Abrir menú");

      openIcon?.classList.remove("opacity-0", "scale-50", "-rotate-90");
      openIcon?.classList.add("opacity-100", "scale-100", "rotate-0");

      closeIcon?.classList.remove("opacity-100", "scale-100", "rotate-0");
      closeIcon?.classList.add("opacity-0", "scale-50", "-rotate-90");
    };

    toggle.addEventListener("click", () => {
      isOpen = !isOpen;

      if (isOpen) {
        mobileMenu.classList.remove("grid-rows-[0fr]", "opacity-0");
        mobileMenu.classList.add("grid-rows-[1fr]", "opacity-100");

        openIcon?.classList.remove("opacity-100", "scale-100", "rotate-0");
        openIcon?.classList.add("opacity-0", "scale-50", "-rotate-90");

        closeIcon?.classList.remove("opacity-0", "scale-50", "-rotate-90");
        closeIcon?.classList.add("opacity-100", "scale-100", "rotate-0");
      } else {
        closeMenu();
      }

      toggle.setAttribute("aria-expanded", String(isOpen));
      toggle.setAttribute("aria-label", isOpen ? "Cerrar menú" : "Abrir menú");
    });

    mobileMenu.querySelectorAll("[data-close-menu]").forEach((link) => {
      link.addEventListener("click", closeMenu);
    });

    document.addEventListener("click", (event) => {
      if (
        isOpen &&
        !toggle.contains(event.target as Node) &&
        !mobileMenu.contains(event.target as Node)
      ) {
        closeMenu();
      }
    });
  }

  function initDropdowns() {
    document.querySelectorAll<HTMLElement>("[data-dropdown]").forEach((li) => {
      const trigger = li.querySelector<HTMLElement>("[data-dropdown-trigger]");
      if (!trigger) return;
      const setOpen = (value: boolean) => {
        trigger.setAttribute("aria-expanded", String(value));
        if (value) li.dataset.open = "true";
        else delete li.dataset.open;
      };
      li.addEventListener("mouseenter", () => setOpen(true));
      li.addEventListener("mouseleave", () => setOpen(false));
      li.addEventListener("focusin", () => setOpen(true));
      li.addEventListener("focusout", (e) => {
        if (!li.contains(e.relatedTarget as Node)) setOpen(false);
      });
      trigger.addEventListener("keydown", (e) => {
        if (e.key === "Escape") {
          setOpen(false);
          trigger.focus();
        }
      });
    });
    document.addEventListener("click", (e) => {
      document
        .querySelectorAll<HTMLElement>("[data-dropdown]")
        .forEach((li) => {
          if (li.contains(e.target as Node)) return;
          const trigger = li.querySelector<HTMLElement>(
            "[data-dropdown-trigger]",
          );
          trigger?.setAttribute("aria-expanded", "false");
          delete li.dataset.open;
        });
    });
  }

  document.addEventListener("astro:page-load", initHeader);
  document.addEventListener("astro:page-load", initDropdowns);
  initHeader();
  initDropdowns();
</script>
