---
import SectionHeader from "@/components/SectionHeader.astro";

interface Props {
  data: any;
}

const { data } = Astro.props;
const { title, subtitle, steps, enable } = data.frontmatter;
---

{
  enable && (
    <section id="how-it-works" class="px-4 py-16 md:py-24">
      <div class="container mx-auto max-w-6xl">
        <SectionHeader title={title} subtitle={subtitle} />

        <div class="relative grid gap-8 sm:grid-cols-2 lg:grid-cols-4 lg:gap-6">
          {/* Horizontal connector — desktop only, sits behind the numbered nodes */}
          <div
            class="hidden lg:block absolute top-6 left-[12.5%] right-[12.5%] border-t border-border"
            aria-hidden="true"
          >
          </div>

          {steps.map((step: any, index: number) => (
            <div class="relative flex flex-col items-center text-center">
              <div class="flex h-12 w-12 items-center justify-center rounded-full border-4 border-body bg-primary text-lg font-bold text-white">
                {index + 1}
              </div>
              <h3 class="mt-5 text-lg font-semibold text-text-light">
                {step.title}
              </h3>
              <p class="mt-2 text-sm leading-relaxed text-text">
                {step.content}
              </p>
            </div>
          ))}
        </div>
      </div>
    </section>
  )
}
