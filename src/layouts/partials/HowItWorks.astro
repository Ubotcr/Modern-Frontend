---
import SectionHeader from "@/components/SectionHeader.astro";

interface Props {
  data: any;
}

const { data } = Astro.props;
const { title, subtitle, steps, enable } = data.frontmatter;
---

{
  enable && (
    <section id="how-it-works" class="px-4 py-16 md:py-24">
      <div class="container mx-auto max-w-6xl">
        <SectionHeader title={title} subtitle={subtitle} />

        <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
          {steps.map((step: any, index: number) => (
            <div class="relative rounded-xl border border-border bg-card p-6 text-center shadow-sm transition-all hover:-translate-y-0.5 hover:border-primary/30 hover:shadow-md">
              <div class="mx-auto flex h-12 w-12 items-center justify-center rounded-full bg-primary text-lg font-bold text-white shadow-sm">
                {index + 1}
              </div>
              <h3 class="mt-4 text-lg font-semibold text-text-light">
                {step.title}
              </h3>
              <p class="mt-2 text-sm leading-relaxed text-gray">
                {step.content}
              </p>
            </div>
          ))}
        </div>
      </div>
    </section>
  )
}
