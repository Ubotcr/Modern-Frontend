---
import SectionHeader from "@/components/SectionHeader.astro";

interface Props {
  data: any;
}

const { data } = Astro.props;
const { title, team_list } = data;
---

<section class="px-4 py-16 md:py-24">
  <div class="container mx-auto max-w-5xl">
    <SectionHeader title={title} />

    <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
      {
        team_list.map((member: any) => (
          <div class="rounded-xl border border-border bg-card p-5 text-center shadow-sm transition-all hover:-translate-y-0.5 hover:shadow-md">
            <div class="mx-auto flex h-16 w-16 items-center justify-center rounded-full bg-primary/10 text-2xl font-bold text-primary">
              {member.name.charAt(0)}
            </div>
            <h3 class="mt-4 text-base font-semibold text-text-light">
              {member.name}
            </h3>
            <p class="mt-1 text-xs text-gray">{member.position}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>
