---
import { markdownify } from "@/lib/utils/textConverter";

interface Props {
  page_header: any;
}

const { page_header } = Astro.props;
const { title, subtitle } = page_header || {};
---

{
  title && (
    <section class="border-b border-border px-4 pb-16 pt-10 text-center md:pt-14">
      <div class="container mx-auto max-w-3xl">
        <h1
          class="mt-4 font-extrabold text-text-light"
          style="font-size: clamp(2.25rem, 6vw, 3.75rem); text-wrap: balance;"
          set:html={markdownify(title).__html}
        />
        {subtitle && <p class="mx-auto mt-4 max-w-xl text-text">{subtitle}</p>}
      </div>
    </section>
  )
}
