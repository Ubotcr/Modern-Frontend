---
import SectionHeader from "@/components/SectionHeader.astro";
import Icon from "@/components/Icon.astro";

interface Props {
  data: any;
}

const { data } = Astro.props;
const { title, subtitle, pricing_plans, enable } = data.frontmatter;

const FALLBACK_RATE = 500;
const formatCRC = (n: number) =>
  new Intl.NumberFormat("es-CR", { maximumFractionDigits: 0 }).format(n);
---

{
  enable && (
    <section id="pricing" class="px-4 py-12 md:py-20">
      <div class="container mx-auto max-w-5xl">
        <SectionHeader title={title} subtitle={subtitle} />

        <div class="grid gap-6 md:grid-cols-2">
          {pricing_plans.map((plan: any) => (
            <div
              class:list={[
                "flex flex-col rounded-2xl border p-6 shadow-sm transition-all md:p-8",
                plan.highlighted
                  ? "border-premium/50 bg-premium/5 shadow-premium/10 hover:shadow-lg"
                  : "border-border bg-card hover:-translate-y-0.5 hover:shadow-md",
              ]}
            >
              <div class="flex items-center justify-between">
                <span class="text-xs font-semibold uppercase tracking-wide text-gray">
                  {plan.name}
                </span>
                {plan.highlighted && (
                  <span class="rounded-full bg-premium px-2 py-0.5 text-xs font-semibold text-amber-950">
                    Popular
                  </span>
                )}
              </div>

              <div class="mt-4" data-price-usd={plan.price}>
                <div class="flex items-baseline gap-1">
                  <span class="text-2xl font-semibold text-gray">₡</span>
                  <span
                    class="text-5xl font-extrabold text-text-light"
                    data-crc-price
                  >
                    {formatCRC(Math.round(plan.price * FALLBACK_RATE))}
                  </span>
                  <span class="text-gray">/ {plan.period}</span>
                </div>
                <p class="mt-1 text-sm text-text">
                  <span>≈ </span>
                  <span class="font-medium text-text-light">${plan.price}</span>
                  USD
                </p>
              </div>

              <p class="mt-3 text-sm text-text">{plan.description}</p>

              <ul class="mt-6 flex flex-1 flex-col gap-3">
                {plan.features.map((feature: string) => (
                  <li class="flex items-start gap-3 text-sm text-text-light">
                    <span class="mt-0.5 flex h-4 w-4 shrink-0 items-center justify-center rounded-full bg-success/15 text-xs text-success">
                      <Icon name="check" class="text-sm" />
                    </span>
                    {feature}
                  </li>
                ))}
              </ul>

              {plan.button?.enable && (
                <a
                  href={plan.button.link}
                  target="_blank"
                  rel="noopener noreferrer"
                  class:list={[
                    "mt-8 w-full rounded-md px-4 py-3 text-center text-sm font-semibold transition-colors",
                    plan.highlighted
                      ? "bg-premium text-amber-950 hover:bg-premium/90"
                      : "border border-border bg-body text-text-light hover:bg-card",
                  ]}
                >
                  {plan.button.label}
                </a>
              )}
            </div>
          ))}
        </div>

        <div class="mt-8 space-y-1 text-center text-xs text-gray">
          <p data-rate-note>
            Los precios en colones son aproximados (tipo de cambio referencial ≈
            ₡{formatCRC(FALLBACK_RATE)} por USD).
          </p>
          <p>
            Los precios pueden variar. Cancela cuando quieras. Pago seguro por
            PayPal.
          </p>
        </div>
      </div>
    </section>
  )
}

<script>
  const API_URL = "https://open.er-api.com/v6/latest/USD";
  const CACHE_KEY = "ubot_usd_crc_rate";
  const CACHE_TTL = 1000 * 60 * 60;

  const formatCRC = (n: number) =>
    new Intl.NumberFormat("es-CR", { maximumFractionDigits: 0 }).format(n);

  function getCachedRate(): number | null {
    try {
      const raw = localStorage.getItem(CACHE_KEY);
      if (!raw) return null;
      const { rate, ts } = JSON.parse(raw);
      if (Date.now() - ts > CACHE_TTL) return null;
      return typeof rate === "number" ? rate : null;
    } catch {
      return null;
    }
  }

  function setCachedRate(rate: number) {
    try {
      localStorage.setItem(CACHE_KEY, JSON.stringify({ rate, ts: Date.now() }));
    } catch {}
  }

  function applyRate(rate: number) {
    document.querySelectorAll<HTMLElement>("[data-price-usd]").forEach((el) => {
      const usd = Number(el.dataset.priceUsd);
      if (!Number.isFinite(usd)) return;
      const crcEl = el.querySelector<HTMLElement>("[data-crc-price]");
      if (crcEl) crcEl.textContent = formatCRC(Math.round(usd * rate));
    });
    const note = document.querySelector<HTMLElement>("[data-rate-note]");
    if (note)
      note.textContent = `Los precios en colones son aproximados (tipo de cambio referencial ≈ ₡${formatCRC(Math.round(rate))} por USD).`;
  }

  async function initPricingConversion() {
    if (!document.querySelector("[data-price-usd]")) return;

    const cached = getCachedRate();
    if (cached) {
      applyRate(cached);
      return;
    }

    try {
      const res = await fetch(API_URL);
      if (!res.ok) throw new Error("network");
      const data = await res.json();
      const rate = data?.rates?.CRC;
      if (typeof rate !== "number" || !Number.isFinite(rate))
        throw new Error("no rate");
      setCachedRate(rate);
      applyRate(rate);
    } catch {
      // keep server-rendered fallback rate
    }
  }

  initPricingConversion();
</script>
