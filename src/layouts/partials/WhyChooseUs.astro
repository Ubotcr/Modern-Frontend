---
import SectionHeader from "@/components/SectionHeader.astro";

interface Props {
  data: any;
}

const { data } = Astro.props;
const { title, feature_list, enable } = data.frontmatter;
---

{
  enable && (
    <section class="border-y border-border bg-card px-4 py-14 md:py-20">
      <div class="container mx-auto max-w-5xl">
        <SectionHeader title={title} />

        <div class="grid gap-10 md:grid-cols-3 md:gap-14">
          {feature_list.map((item: any) => (
            <div>
              <h3 class="text-xl font-semibold text-text-light">
                {item.title}
              </h3>
              <p class="mt-3 text-sm leading-relaxed text-text">
                {item.content}
              </p>
            </div>
          ))}
        </div>
      </div>
    </section>
  )
}
