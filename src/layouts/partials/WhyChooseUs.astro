---
import SectionHeader from "@/components/SectionHeader.astro";
import Icon from "@/components/Icon.astro";

interface Props {
  data: any;
}

const { data } = Astro.props;
const { title, feature_list, enable } = data.frontmatter;
---

{
  enable && (
    <section class="border-y border-border bg-card px-4 py-12 md:py-20">
      <div class="container mx-auto max-w-6xl">
        <SectionHeader title={title} />

        <div class="grid gap-8 md:grid-cols-3">
          {feature_list.map((item: any) => (
            <div class="rounded-xl p-6 transition-colors hover:bg-body/50">
              <span class="flex h-12 w-12 items-center justify-center rounded-xl bg-primary/10 text-2xl text-primary">
                <Icon name={item.icon} class="text-[1.5rem]" />
              </span>
              <h3 class="mt-4 text-lg font-semibold text-text-light">
                {item.title}
              </h3>
              <p class="mt-2 text-sm leading-relaxed text-gray">
                {item.content}
              </p>
            </div>
          ))}
        </div>
      </div>
    </section>
  )
}
