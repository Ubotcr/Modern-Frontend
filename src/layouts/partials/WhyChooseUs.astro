---
import SectionHeader from "@/components/SectionHeader.astro";
import Icon from "@/components/Icon.astro";

interface Props {
  data: any;
}

const { data } = Astro.props;
const { title, feature_list, enable } = data.frontmatter;
---

{
  enable && (
    <section class="border-y border-border bg-card px-4 py-14 md:py-20">
      <div class="container mx-auto max-w-5xl">
        <SectionHeader title={title} />

        <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
          {feature_list.map((item: any) => (
            <article class="group relative rounded-xl border border-border bg-body p-6 shadow-sm transition-all hover:-translate-y-0.5 hover:border-primary/30 hover:shadow-md">
              <span class="flex h-12 w-12 items-center justify-center rounded-xl bg-primary/10 text-primary">
                <Icon name={item.icon} class="text-2xl" />
              </span>
              <h3 class="mt-4 text-lg font-semibold text-text-light">
                {item.title}
              </h3>
              <p class="mt-2 text-sm leading-relaxed text-text">
                {item.content}
              </p>
            </article>
          ))}
        </div>
      </div>
    </section>
  )
}
