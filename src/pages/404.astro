---
import Base from "@/layouts/Base.astro";
---

<Base
  title="Página no encontrada"
  meta_title="404"
  description="La página que buscas no existe."
>
  <section class="px-4 py-24 text-center md:py-32">
    <div class="container mx-auto max-w-xl">
      <h1 class="text-8xl font-extrabold text-primary">404</h1>
      <p class="mt-4 text-2xl font-semibold text-text-light">
        Página no encontrada
      </p>
      <p class="mt-2 text-gray">La página que buscas no existe o fue movida.</p>
      <a href="/" class="btn btn-primary mt-8 inline-flex">Volver al inicio</a>
    </div>
  </section>
</Base>
