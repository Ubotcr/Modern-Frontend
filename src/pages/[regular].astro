---
import Base from "@/layouts/Base.astro";
import PageHeader from "@/partials/PageHeader.astro";
import { getSinglePage } from "@/lib/contentParser.astro";
import { render } from "astro:content";

export async function getStaticPaths() {
  const pages = await getSinglePage("pages");
  return pages.map((page: any) => ({
    params: { regular: page.id },
    props: { page },
  }));
}

const { page } = Astro.props;

if (page.data.draft) return Astro.redirect("/404");

const { Content } = await render(page);
const { title, meta_title, description, page_header } = page.data;
---

<Base title={title} meta_title={meta_title} description={description}>
  {page_header && <PageHeader page_header={page_header} />}
  <section class="px-4 py-12 md:py-16">
    <div class="container mx-auto max-w-3xl content">
      <Content />
    </div>
  </section>
</Base>
