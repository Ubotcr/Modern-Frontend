---
import Base from "@/layouts/Base.astro";
import CallToAction from "@/partials/CallToAction.astro";
import PageHeader from "@/partials/PageHeader.astro";
import OurTeam from "@/partials/OurTeam.astro";
import Icon from "@/components/Icon.astro";
import { getListPage } from "@/lib/contentParser";

const data = await getListPage("about/-index.md");
const { title, description, meta_title, page_header, who_we_are, our_team } =
  data.frontmatter;
const callToAction = await getListPage("sections/call-to-action.md");
---

<Base title={title} meta_title={meta_title} description={description}>
  <PageHeader page_header={page_header} />

  <section class="px-4 py-12 md:py-20">
    <div class="container mx-auto max-w-5xl">
      <div class="grid gap-12 md:grid-cols-2 md:items-center">
        <div>
          <h2 class="mt-3 text-2xl font-bold text-text-light md:text-3xl">
            {who_we_are.title}
          </h2>
          <p class="mt-4 text-gray">{who_we_are.subtitle}</p>
        </div>

        <div class="flex flex-col gap-4">
          {
            [
              {
                icon: who_we_are.mission.icon,
                title: who_we_are.mission.title,
                content: who_we_are.mission.content,
              },
              {
                icon: who_we_are.problem.icon,
                title: who_we_are.problem.title,
                content: who_we_are.problem.content,
              },
              {
                icon: who_we_are.solution.icon,
                title: who_we_are.solution.title,
                content: who_we_are.solution.content,
              },
            ].map((item) => (
              <div class="flex items-start gap-4 rounded-xl border border-border bg-card p-4 shadow-sm">
                <span class="flex h-10 w-10 shrink-0 items-center justify-center rounded-lg bg-primary/10 text-xl text-primary">
                  <Icon name={item.icon} class="text-[1.25rem]" />
                </span>
                <div>
                  <h3 class="font-semibold text-text-light">{item.title}</h3>
                  <p class="mt-1 text-sm text-gray">{item.content}</p>
                </div>
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </section>

  <OurTeam data={our_team} />
  <CallToAction data={callToAction} />
</Base>
