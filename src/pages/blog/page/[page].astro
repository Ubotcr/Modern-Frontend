---
import Base from "@/layouts/Base.astro";
import BlogCard from "@/components/BlogCard.astro";
import Pagination from "@/components/Pagination.astro";
import CallToAction from "@/partials/CallToAction.astro";
import PageHeader from "@/partials/PageHeader.astro";
import config from "@/config/config.json";
import { getCollection } from "astro:content";
import { getListPage } from "@/lib/contentParser";
import { sortByDate } from "@/lib/utils/blog";

export async function getStaticPaths() {
  const perPage = config.settings.pagination ?? 6;
  const all = await getCollection(
    "blog",
    ({ id, data }) => !id.startsWith("-") && !id.startsWith("_") && !data.draft,
  );
  const totalPages = Math.ceil(all.length / perPage);
  const paths = [];
  for (let i = 2; i <= totalPages; i++) {
    paths.push({ params: { page: String(i) } });
  }
  return paths;
}

const { page } = Astro.params;
const currentPage = Number(page) || 1;

const index = await getListPage("blog/-index.md");
const { title, meta_title, description, image, page_header } =
  index.frontmatter as any;
const header = page_header ?? { title, subtitle: description };

const posts = sortByDate(
  (
    await getCollection(
      "blog",
      ({ id, data }) =>
        !id.startsWith("-") && !id.startsWith("_") && !data.draft,
    )
  ).map((p) => ({ frontmatter: p.data, slug: p.id, content: p.body })),
);

const perPage = config.settings.pagination ?? 6;
const totalPages = Math.max(1, Math.ceil(posts.length / perPage));
const start = (currentPage - 1) * perPage;
const current = posts.slice(start, start + perPage);
const callToAction = await getListPage("sections/call-to-action.md");
---

<Base
  title={title}
  meta_title={meta_title}
  description={description}
  image={image}
>
  <PageHeader page_header={header} />

  <section class="px-4 py-12 md:py-16">
    <div class="container mx-auto max-w-6xl">
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {current.map((post) => <BlogCard data={post} />)}
      </div>

      <Pagination
        section="blog"
        currentPage={currentPage}
        totalPages={totalPages}
      />
    </div>
  </section>

  <CallToAction data={callToAction} />
</Base>
