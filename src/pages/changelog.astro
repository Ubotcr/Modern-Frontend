---
import Base from "@/layouts/Base.astro";
import CallToAction from "@/partials/CallToAction.astro";
import PageHeader from "@/partials/PageHeader.astro";
import { getListPage } from "@/lib/contentParser";

const data = await getListPage("changelog/-index.md");
const { title, description, meta_title, page_header, changelog_list } =
  data.frontmatter;
const callToAction = await getListPage("sections/call-to-action.md");
---

<Base title={title} meta_title={meta_title} description={description}>
  <PageHeader page_header={page_header} />

  {
    changelog_list && changelog_list.length > 0 && (
      <section class="px-4 py-12 md:py-20">
        <div class="container mx-auto max-w-3xl">
          <div class="flex flex-col gap-6">
            {changelog_list.map((item: any) => (
              <div class="rounded-lg border border-border bg-card p-6">
                <div class="flex flex-wrap items-center gap-3">
                  <span class="rounded-full bg-primary/10 px-3 py-1 text-xs font-semibold text-primary">
                    v{item.version}
                  </span>
                  <span class="text-sm text-gray">{item.date}</span>
                </div>
                <h2 class="mt-3 text-lg font-semibold text-text-light">
                  {item.title}
                </h2>
                <p class="mt-2 text-sm text-text">{item.description}</p>
              </div>
            ))}
          </div>
        </div>
      </section>
    )
  }

  <CallToAction data={callToAction} />
</Base>
