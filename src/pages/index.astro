---
import Base from "@/layouts/Base.astro";
import CalendarWidget from "@/components/CalendarWidget.astro";
import Hero from "@/components/Hero.astro";
import CallToAction from "@/partials/CallToAction.astro";
import EssentialFeatures from "@/partials/EssentialFeatures.astro";
import FAQ from "@/partials/FAQ.astro";
import Gallery from "@/partials/Gallery.astro";
import HowItWorks from "@/partials/HowItWorks.astro";
import Pricing from "@/partials/Pricing.astro";
import WhyChooseUs from "@/partials/WhyChooseUs.astro";
import { getListPage } from "@/lib/contentParser";

const homepage = await getListPage("homepage/-index.md");
const essentialFeatures = await getListPage("sections/essential-features.md");
const whyChooseUs = await getListPage("sections/why-choose-us.md");
const howItWorks = await getListPage("sections/how-it-works.md");
const gallery = await getListPage("sections/gallery.md");
const pricing = await getListPage("sections/pricing.md");
const faq = await getListPage("sections/faq.md");
const callToAction = await getListPage("sections/call-to-action.md");
const { banner } = homepage.frontmatter;
---

<Base>
  <Hero data={banner} />
  <EssentialFeatures data={essentialFeatures} />
  <Gallery data={gallery} />
  <WhyChooseUs data={whyChooseUs} />
  <HowItWorks data={howItWorks} />
  <Pricing data={pricing} />
  <FAQ data={faq} />
  <CalendarWidget />
  <CallToAction data={callToAction} />
</Base>
