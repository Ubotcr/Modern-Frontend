{
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": [
      "/*.xml",
      "/*.js",
      "/*.css",
      "/*.png",
      "/*.jpg",
      "/*.svg",
      "/assets/*"
    ]
  },
  "responseOverrides": {
    "404": {
      "rewrite": "/404.html",
      "statusCode": 404
    }
  },
  "routes": [
    {
      "route": "/sitemap.xml",
      "rewrite": "/sitemap-index.xml"
    },
    {
      "route": "/*.html",
      "headers": {
        "Cache-Control": "no-cache, no-store, must-revalidate",
        "Pragma": "no-cache"
      }
    },
    {
      "route": "/",
      "headers": {
        "Cache-Control": "no-cache, no-store, must-revalidate",
        "Pragma": "no-cache"
      }
    },
    {
      "route": "/blog/*",
      "headers": {
        "Cache-Control": "public, max-age=0, must-revalidate"
      }
    },
    {
      "route": "/_content/*",
      "headers": {
        "Cache-Control": "public, max-age=31536000, immutable"
      }
    },
    {
      "route": "/_astro/*",
      "headers": {
        "Cache-Control": "public, max-age=31536000, immutable"
      }
    }
  ],
  "outputDir": "dist"
}